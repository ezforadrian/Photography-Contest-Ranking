@using System;
@using System.Globalization;
@using photoCon.Dto;
@using photoCon.Helper;
@{
    LocalEncryption localEncryption = new LocalEncryption();
    const string key = "thequickbrownfox";
}
<link href="~/lib/bootstrap/dist/css/datatables.min.css" rel="stylesheet">
<script src="~/lib/jquery/dist/datatables.min.js"></script>
<div class="container-fluid">
    <div class="row col-8">
        <form class="row col-12">
            @Html.AntiForgeryToken()
            <div class="col-6">
                <div class="input-group m-2">
                    <label class="col-4">User Type: </label>
                    <select id="fieldUserType" class="form-select col-auto">
                        @if ((this.User.IsInRole("SYSADMIN") || this.User.IsInRole("APPADMIN")) && User.Identity.IsAuthenticated)
                        {
                            <option value="ECDUSER">ECD User</option>
                        }
                        @if ((this.User.IsInRole("SYSADMIN") || this.User.IsInRole("APPADMIN") || this.User.IsInRole("ECDUSER")) && User.Identity.IsAuthenticated)
                        {
                            <option value="JUDGE">Judge</option>
                        }
                    </select>
                </div>
                <div class="input-group m-2 m-2">
                    <label class="col-4"><span class="text-danger"></span></label>
                    <label class="col-8"><span class="text-danger" style="font-size: 12px">Username must be alphanumeric. Minimum of 6 characters.</span> </label>
                </div>
                <div class="input-group m-2 m-2">
                    <label class="col-4">Username<span class="text-danger">*</span>: </label>
                    <input id="fieldUserName" type="text" class="form-control" />
                    <input id="fieldUserId" type="hidden" class="form-control" />
                </div>
                
         
                <div class="input-group m-2">
                    <label class="col-4">Last Name<span class="text-danger">*</span>: </label>
                    <input id="fieldLastName" type="text" class="form-control" />
                </div>
                <div class="input-group m-2">
                    <label class="col-4">First Name<span class="text-danger">*</span>: </label>
                    <input id="fieldFirstName" type="text" class="form-control" />
                </div>
                <div class="input-group m-2">
                    <label class="col-4">Middle Initial: </label>
                    <input id="fieldMiddleInitial" type="text" class="form-control" />
                </div>
            </div>
            <div class="col-6">
                <div class="input-group m-2">
                    <label class="col-4">Department/Division<span class="text-danger">*</span>:</label>
                    <input id="fieldDepartment" type="text" class="form-control" />
                </div>
                <div class="input-group m-2" style="display:none;">
                    <label class="col-4">Job Title<span class="text-danger">*</span>: </label>
                    <input id="fieldJobTitle" type="hidden" class="form-control" />
                </div>
                <div class="input-group m-2">
                    <label class="col-4">E-Mail Address: </label>
                    <input id="fieldEMail" type="text" class="form-control" />
                </div>
                <div class="input-group m-2 m-2">
                    <label class="col-4"><span class="text-danger"></span></label>
                    <label class="col-8"><span class="text-danger" style="font-size: 12px">Password must be alphanumeric. Minimum of 6 characters.</span> </label>
                </div>
                <div class="input-group m-2">
                    <label class="col-4">Password<span class="text-danger">*</span>: </label>
                    <input id="fieldPassword" type="password" class="form-control" placeholder="" />
                </div>
            </div>
        </form>

        <div>
            <input type="button" class="btn btn-primary" id="btnEnrollUser" value="Enroll" />
            <input type="button" class="btn btn-primary" id="btnUpdateUser" value="Save Changes" style="display: none;" />
            <input type="button" class="btn btn-danger" id="btnCancelEditMode" value="Cancel Edit" style="display: none;">
        </div>
    </div>
    <div>
        <table id="usersTable" class="table">
            <thead class="w-auto">
                <tr>
                    <th style="width:10%;">User Name</th>
                    <th style="width:15%;">First Name</th>
                    <th style="width:15%;">Last Name</th>
                    <th style="width:15%;">Middle Name</th>
                    <th style="width:20%;">E-Mail</th>
                    <th style="width:20%;">Option</th>
                    <th style="width:auto;"></th>
                </tr>
            </thead>
            <tbody id="usersTableBody"></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalSystemMessage" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5>System Message</h5>
            </div>

            <div class="modal-body">
                <span id="txtSystemMessage"></span>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalConfirmDelete" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5>System Message</h5>
            </div>

            <div class="modal-body">
                <span>Are you sure you want to delete this user?</span>
            </div>

            <div class="modal-footer d-flex justify-content-evenly">
                <button class="btn btn-success d-flex" id="btnConfirmDelete" style="padding-left: 40px;padding-right: 40px;" data-bs-dismiss="modal">Yes</button>
                <button class="btn btn-danger d-flex" style="padding-left: 40px;padding-right: 40px;" data-bs-dismiss="modal">No</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/Enrollment/_enrollment_index.js?v1r1.0"></script>