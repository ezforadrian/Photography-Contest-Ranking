@using System
@using System.Globalization
@using photoCon.Services
@using photoCon.Dto
@using photoCon.Helper
@{
    LocalEncryption localEncryption = new LocalEncryption();
    const string key = "thequickbrownfox";
}
@Html.AntiForgeryToken()

<link href="~/lib/bootstrap/dist/css/datatables.min.css" rel="stylesheet">
<script src="~/lib/jquery/dist/datatables.min.js"></script>
<style>
    .warningMessage_ {
        margin: 0px;
        font-size: small;
        font-style: italic;
        color: red;
    }

    .modal-backdrop.show {
        z-index: 1040;
    }

    #errorModal {
        z-index: 1050;
    }

    #inputGroup-sizing-sm {
        background-color: white;
        font-size: 11px;
    }
</style>

<div class="container-fluid">
    <h1>Regional Dates</h1>
    <div class="col-5 col-sm-5">
        <form id="prelimDateForm" method="post" action="AddPrelimDates">
            
            <br />
            <div class="input-group">
                <span class="input-group-text fw-bold">Regional Date: </span>
                <input type="date" class="form-control" id="prelimStartDate">
                <button class="btn btn-outline-primary fw-bold" id="btnSubmitPrelim" type="submit"> <i class="fa-solid fa-plus"></i> &nbsp;Add Date</button>
            </div>
            <br />
        </form>

    </div>
    <div class="col-12 col-sm-12">
        <table class="table thead-dark" id="prelimListTable" width="100%">
            <thead>
                <tr>
                    <th>#</th>
                    <th scope="col" class="text-center">Day Number</th>
                    <th scope="col" class="text-center">Date</th>
                    <th scope="col" class="text-center">Status</th>
                    <th scope="col" class="text-center">Round</th>
                    <th scope="col" class="text-center">
                        Qualifying Number Per Round
                        <br /> Round1/Round2
                    </th>
                    <th scope="col" class="text-center">Final Status<br />(Ongoing / Completed)</th>
                    <th scope="col" class="text-center">Finalist Count</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>


    <!-- Success Modal -->
    <div class="modal fade" id="successModal" tabindex="-1" aria-labelledby="successModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="successModalLabel">Success</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="successModalBody">
                    <!-- Success message will be inserted here -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Error Modal -->
    <div class="modal fade" id="errorModal" tabindex="-1" aria-labelledby="errorModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="errorModalLabel">Error</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="errorModalBody">
                    <!-- Error messages will be inserted here -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Confirm Delete Modal -->
    <div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmDeleteModalLabel">Confirm Deletion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to remove this record?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Remove</button>
                </div>
            </div>
        </div>
    </div>


    <!-- Confirm Open Modal -->
    <div class="modal fade" id="confirmOpenModal" tabindex="-1" aria-labelledby="confirmOpenModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmOpenModalLabel">Confirm Open Date</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to open this date?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmOpenBtn">Open</button>
                </div>
            </div>
        </div>
    </div>


    <!-- Edit Modal -->
    <div class="modal fade" id="editInfoModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="editInfoLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="editInfoLabel">Edit Regional Date</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="hashRowIdProcessParam" />
                    <div class="row">
                        <div class="col-8">
                            <div class="input-group input-group-sm mb-3 spanclassMain">
                                <span class="input-group-text col-6" id="inputGroup-sizing-sm">Day Number: </span>
                                <input type="text" class="form-control col-6" id="ppdayNumber" readonly>
                            </div>
                            <div class="input-group input-group-sm mb-3 spanclassMain" style="margin-top: -17px;">
                                <span class="input-group-text col-6" id="inputGroup-sizing-sm">Date: </span>
                                <input type="text" class="form-control col-6" id="ppdate" readonly>
                            </div>
                            <div class="input-group input-group-sm mb-3 spanclassMain" style="margin-top: -17px;">
                                <span class="input-group-text col-6" id="inputGroup-sizing-sm">Image Batch Count: </span>
                                <input type="text" class="form-control col-6" id="imageBatchCount" readonly>
                            </div>
                        </div>
                    </div>
                    <hr />
                    <form id="updateBatch">
                        <div class="row">
                            <div class="col-6">
                                <mark><label class="form-label">Select Region:</label></mark>
                                <div id="regionCheckboxes"></div>
                            </div>
                            <div class="col-6">
                                <mark><label class="form-label">Select Categories:</label></mark>
                                <div id="categoryCheckboxes"></div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6"></div>
                            <div class="col-3"></div>
                            <div class="col-3">
                                <button class="btn btn-primary btn-lg" type="submit">Submit Batch</button>
                            </div>
                        </div>
                    </form>
                    <hr />

                    <form id="initialRound">
                        <div class="row">
                            <div class="col-6">
                                <mark><label class="form-label">Regional Round One:</label></mark>
                                <div class="input-group input-group-sm mb-3 spanclassMain">
                                    <span class="input-group-text col-6" id="inputGroup-sizing-sm">Qualifying Number: </span>
                                    <input type="number" class="form-control col-6" id="InitialFinNumber" required>
                                    <input type="hidden" id="roundInfoOne" value="@localEncryption.ANEncrypt("1", key)">
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <button class="btn btn-primary btn-lg" type="button" id="btnCloseInitialRound">Close Round One</button>
                                <p class="fst-italic fw-bold" style="color: red;"><small>Before closing the round, ensure that the judges have finished scoring all images.</small></p>
                            </div>
                        </div>
                    </form>
                    <hr />
                    <form id="initialRound">
                        <div class="row">
                            <div class="col-6">
                                <mark><label class="form-label">Regional Round Two:</label></mark>
                                <div class="input-group input-group-sm mb-3 spanclassMain">
                                    <span class="input-group-text col-6" id="inputGroup-sizing-sm">Qualifying Number: </span>
                                    <input type="number" class="form-control col-6" id="InitialFinNumberTwo" required>
                                    <input type="hidden" id="roundInfoTwo" value="@localEncryption.ANEncrypt("2", key)">
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <button class="btn btn-primary btn-lg" type="button" id="btnCloseInitialRoundTwo">Close Round Two</button>
                                <p class="fst-italic fw-bold" style="color: red;"><small>Before closing the round, ensure that the judges have finished scoring all images.</small></p>
                            </div>
                        </div>
                    </form>
                    <hr />
                    <form id="dailyFinalRound">
                        <div class="row">
                            <div class="col-6">
                                <mark><label class="form-label">Regional Round Three:</label></mark>
                                <div class="input-group input-group-sm mb-3 spanclassMain">
                                    <span class="input-group-text col-6" id="inputGroup-sizing-sm">Qualifying Number:</span>
                                    <input type="number" class="form-control col-6" id="RegionalFinNumber" required>
                                    <input type="hidden" id="roundInfoThree" value="@localEncryption.ANEncrypt("3", key)">
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <button class="btn btn-primary btn-lg" type="button" id="btnCompleteDailyRound">Close Round Three</button>
                                <p class="fst-italic fw-bold" style="color: red;"><small>Before closing the day, ensure that the judges have finished scoring all images.</small></p>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Confirm Close Initial Round Modal -->
    <div class="modal fade" id="confirmCloseInitialRoundModal" tabindex="-1" aria-labelledby="confirmCloseInitialRoundModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmCloseInitialRoundModalLabel">Confirm Close Round</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to close this round? 
                    
                    <br />
                    Qualifying number:
                    <input type="number" class="form-control mt-2" id="confirmInitialFinNumber" readonly/>
                    <input type="hidden" id="roundInfoModal" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmCloseInitialRoundBtn">Continue</button>
                </div>
            </div>
        </div>
    </div>

    @* <!-- Confirm Close Daily Round Modal -->
    <div class="modal fade" id="confirmCloseDailyRoundModal" tabindex="-1" aria-labelledby="confirmCloseDailyRoundModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmCloseDailyRoundModalLabel">Confirm Close Daily Round</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to tagged this day as completed?

                    <br />
                    Regional Finalist Number:
                    <input type="number" class="form-control mt-2" id="confirmDailyFinNumber" readonly />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmCloseDailyRoundBtn">Continue</button>
                </div>
            </div>
        </div>
    </div> *@







</div>


<script src="~/js/InitialSetup/_initialsetup_index.js?v1r1.1">

</script>







